{
  "name": "ax-work-observatory",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "remotion:render": "npm run remotion:render:aidlc && npm run remotion:render:logger && npm run remotion:render:content && npm run remotion:render:task",
    "remotion:render:aidlc": "remotion render remotion/index.tsx AIDLCStudioPipeline public/media/aidlc-studio.mp4 --codec=h264 --overwrite",
    "remotion:render:logger": "remotion render remotion/index.tsx AgentConversationLoggerPipeline public/media/agent-conversation-logger.mp4 --codec=h264 --overwrite",
    "remotion:render:content": "remotion render remotion/index.tsx DataToContentPipeline public/media/data-to-content-workflow.mp4 --codec=h264 --overwrite",
    "remotion:render:task": "remotion render remotion/index.tsx AgenticTaskAutomationPipeline public/media/agentic-task-automation.mp4 --codec=h264 --overwrite",
    "remotion:preview": "remotion studio remotion/index.tsx"
  },
  "dependencies": {
    "framer-motion": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "three": "^0.185.0"
  },
  "devDependencies": {
    "@fortawesome/free-brands-svg-icons": "^7.3.0",
    "@remotion/cli": "4.0.484",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/three": "^0.185.0",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "remotion": "4.0.484",
    "typescript": "latest",
    "zod": "4.3.6"
  }
}
